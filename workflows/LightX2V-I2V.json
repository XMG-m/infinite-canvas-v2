{
  "ldimg": {
    "inputs": {
      "image": "{{image}}"
    },
    "class_type": "LoadImage"
  },
  "resize": {
    "inputs": {
      "image": [
        "ldimg",
        0
      ],
      "width": 720,
      "height": 720,
      "crop": "center",
      "keep_proportion": "pad",
      "divisible_by": 16,
      "upscale_method": "lanczos",
      "pad_color": "0,0,0",
      "crop_position": "center"
    },
    "class_type": "ImageResizeKJv2"
  },
  "clip": {
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "wan",
      "device": "cpu"
    },
    "class_type": "CLIPLoader"
  },
  "vae": {
    "inputs": {
      "vae_name": "wan_2.1_vae.safetensors"
    },
    "class_type": "VAELoader"
  },
  "cv": {
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    },
    "class_type": "CLIPVisionLoader"
  },
  "cv_encode": {
    "inputs": {
      "clip_vision": [
        "cv",
        0
      ],
      "image": [
        "resize",
        0
      ],
      "crop": "center"
    },
    "class_type": "CLIPVisionEncode"
  },
  "pos": {
    "inputs": {
      "text": "{{prompt}}",
      "clip": [
        "clip",
        0
      ]
    },
    "class_type": "CLIPTextEncode"
  },
  "neg": {
    "inputs": {
      "text": "blurry, static, distorted, low quality, worst quality",
      "clip": [
        "clip",
        0
      ]
    },
    "class_type": "CLIPTextEncode"
  },
  "unet_h": {
    "inputs": {
      "unet_name": "Wan/wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "class_type": "UNETLoader"
  },
  "lora_h1": {
    "inputs": {
      "lora_name": "Wan/wan2.2_i2v_A14b_high_noise_lora_rank64_lightx2v_4step_1022.safetensors",
      "strength_model": 1.0,
      "model": [
        "unet_h",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "lora_h2": {
    "inputs": {
      "lora_name": "Lightx2v/lightx2v_I2V_14B_480p_cfg_step_distill_rank256_bf16.safetensors",
      "strength_model": 2.0,
      "model": [
        "lora_h1",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "lora_h3": {
    "inputs": {
      "lora_name": "Wan/Wan2.2-Fun-A14B-InP-high-noise-MPS.safetensors",
      "strength_model": 0.5,
      "model": [
        "lora_h2",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "ms_h": {
    "inputs": {
      "shift": 8.0,
      "model": [
        "lora_h3",
        0
      ]
    },
    "class_type": "ModelSamplingSD3"
  },
  "bswap_h": {
    "inputs": {
      "model": [
        "ms_h",
        0
      ]
    },
    "class_type": "wanBlockSwap"
  },
  "sage_h": {
    "inputs": {
      "model": [
        "bswap_h",
        0
      ],
      "sage_attention": "sageattn_qk_int8_pv_fp16_triton",
      "allow_compile": false
    },
    "class_type": "PathchSageAttentionKJ"
  },
  "patch_h": {
    "inputs": {
      "model": [
        "sage_h",
        0
      ],
      "enable_fp16_accumulation": true
    },
    "class_type": "ModelPatchTorchSettings"
  },
  "unet_l": {
    "inputs": {
      "unet_name": "Wan/wan2.2_i2v_low_noise_14B_fp8_scaled.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader"
  },
  "lora_l1": {
    "inputs": {
      "lora_name": "Lightx2v/lightx2v_I2V_14B_480p_cfg_step_distill_rank256_bf16.safetensors",
      "strength_model": 1.0,
      "model": [
        "unet_l",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "lora_l2": {
    "inputs": {
      "lora_name": "Wan/Wan2.2-Fun-A14B-InP-low-noise-HPS2.1.safetensors",
      "strength_model": 0.5,
      "model": [
        "lora_l1",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "ms_l": {
    "inputs": {
      "shift": 8.0,
      "model": [
        "lora_l2",
        0
      ]
    },
    "class_type": "ModelSamplingSD3"
  },
  "bswap_l": {
    "inputs": {
      "model": [
        "ms_l",
        0
      ]
    },
    "class_type": "wanBlockSwap"
  },
  "sage_l": {
    "inputs": {
      "model": [
        "bswap_l",
        0
      ],
      "sage_attention": "sageattn_qk_int8_pv_fp16_triton",
      "allow_compile": false
    },
    "class_type": "PathchSageAttentionKJ"
  },
  "patch_l": {
    "inputs": {
      "model": [
        "sage_l",
        0
      ],
      "enable_fp16_accumulation": true
    },
    "class_type": "ModelPatchTorchSettings"
  },
  "i2v": {
    "inputs": {
      "width": 720,
      "height": 720,
      "length": 81,
      "batch_size": 1,
      "positive": [
        "pos",
        0
      ],
      "negative": [
        "neg",
        0
      ],
      "vae": [
        "vae",
        0
      ],
      "clip_vision_output": [
        "cv_encode",
        0
      ],
      "start_image": [
        "resize",
        0
      ]
    },
    "class_type": "WanImageToVideo"
  },
  "ks_h": {
    "inputs": {
      "add_noise": "enable",
      "noise_seed": 0,
      "steps": 6,
      "cfg": 1.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "simple",
      "start_at_step": 0,
      "end_at_step": 3,
      "return_with_leftover_noise": "enable",
      "model": [
        "patch_h",
        0
      ],
      "positive": [
        "i2v",
        0
      ],
      "negative": [
        "i2v",
        1
      ],
      "latent_image": [
        "i2v",
        2
      ]
    },
    "class_type": "KSamplerAdvanced"
  },
  "ks_l": {
    "inputs": {
      "add_noise": "disable",
      "noise_seed": 0,
      "steps": 6,
      "cfg": 1.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "simple",
      "start_at_step": 3,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable",
      "model": [
        "patch_l",
        0
      ],
      "positive": [
        "i2v",
        0
      ],
      "negative": [
        "i2v",
        1
      ],
      "latent_image": [
        "ks_h",
        0
      ]
    },
    "class_type": "KSamplerAdvanced"
  },
  "decode": {
    "inputs": {
      "samples": [
        "ks_l",
        0
      ],
      "vae": [
        "vae",
        0
      ]
    },
    "class_type": "VAEDecode"
  },
  "out": {
    "inputs": {
      "images": [
        "decode",
        0
      ],
      "frame_rate": 16.0,
      "loop_count": 0,
      "filename_prefix": "wan_i2v_lx2v/",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    },
    "class_type": "VHS_VideoCombine"
  }
}