{
  "ltxdh_ckpt": {
    "inputs": {
      "ckpt_name": "ltx-2.3-22b-dev.safetensors"
    },
    "class_type": "CheckpointLoaderSimple"
  },
  "ltxdh_vae_audio": {
    "inputs": {
      "ckpt_name": "ltx-2.3-22b-dev.safetensors"
    },
    "class_type": "LTXVAudioVAELoader"
  },
  "ltxdh_text_encoder": {
    "inputs": {
      "text_encoder": "gemma_3_12B_it_fp8_e4m3fn.safetensors",
      "ckpt_name": "ltx-2.3-22b-dev.safetensors",
      "device": "default"
    },
    "class_type": "LTXAVTextEncoderLoader"
  },
  "ltxdh_lora": {
    "inputs": {
      "lora_name": "Ltx/ltx-2.3-22b-distilled-lora-384.safetensors",
      "strength_model": 0.5,
      "model": [
        "ltxdh_ckpt",
        0
      ]
    },
    "class_type": "LoraLoaderModelOnly"
  },
  "ltxdh_ref_img": {
    "inputs": {
      "image": "{{image}}"
    },
    "class_type": "LoadImage"
  },
  "ltxdh_img_resize": {
    "inputs": {
      "image": [
        "ltxdh_ref_img",
        0
      ],
      "width": 1281,
      "height": 705,
      "crop": "center",
      "keep_proportion": "pad",
      "divisible_by": 32,
      "upscale_method": "lanczos",
      "pad_color": "0,0,0",
      "crop_position": "center",
      "device": "cpu"
    },
    "class_type": "ImageResizeKJv2"
  },
  "ltxdh_preprocess": {
    "inputs": {
      "image": [
        "ltxdh_img_resize",
        0
      ],
      "img_compression": 18
    },
    "class_type": "LTXVPreprocess"
  },
  "ltxdh_vae": {
    "inputs": {
      "vae_name": "LTX23_video_vae_bf16.safetensors"
    },
    "class_type": "VAELoader"
  },
  "ltxdh_ref_audio": {
    "inputs": {
      "audio": "{{ref_audio}}"
    },
    "class_type": "LoadAudio"
  },
  "ltxdh_i2v": {
    "inputs": {
      "vae": [
        "ltxdh_vae",
        0
      ],
      "image": [
        "ltxdh_preprocess",
        0
      ],
      "latent": [
        "ltxdh_latent",
        0
      ],
      "strength": 1.0,
      "bypass": false
    },
    "class_type": "LTXVImgToVideoInplace"
  },
  "ltxdh_pos_text": {
    "inputs": {
      "text": "{{prompt}}",
      "clip": [
        "ltxdh_text_encoder",
        0
      ]
    },
    "class_type": "CLIPTextEncode"
  },
  "ltxdh_neg_text": {
    "inputs": {
      "text": "subtitles, watermark, blurry, low quality",
      "clip": [
        "ltxdh_text_encoder",
        0
      ]
    },
    "class_type": "CLIPTextEncode"
  },
  "ltxdh_cond": {
    "inputs": {
      "positive": [
        "ltxdh_pos_text",
        0
      ],
      "negative": [
        "ltxdh_neg_text",
        0
      ],
      "frame_rate": 24
    },
    "class_type": "LTXVConditioning"
  },
  "ltxdh_latent": {
    "inputs": {
      "width": 1281,
      "height": 705,
      "length": 121,
      "batch_size": 1
    },
    "class_type": "EmptyLTXVLatentVideo"
  },
  "ltxdh_audio_encode": {
    "inputs": {
      "audio": [
        "ltxdh_ref_audio",
        0
      ],
      "vae": [
        "ltxdh_vae_audio",
        0
      ]
    },
    "class_type": "VAEEncodeForInference"
  },
  "ltxdh_av_latent": {
    "inputs": {
      "video_latent": [
        "ltxdh_i2v",
        0
      ],
      "audio_latent": [
        "ltxdh_audio_encode",
        0
      ]
    },
    "class_type": "LTXVConcatAVLatent"
  },
  "ltxdh_sage": {
    "inputs": {
      "model": [
        "ltxdh_lora",
        0
      ],
      "sage_attention": "auto",
      "allow_compile": false
    },
    "class_type": "PathchSageAttentionKJ"
  },
  "ltxdh_chunk": {
    "inputs": {
      "model": [
        "ltxdh_sage",
        0
      ],
      "chunks": 4,
      "dim_threshold": 4096
    },
    "class_type": "LTXVChunkFeedForward"
  },
  "ltxdh_attn_tune": {
    "inputs": {
      "model": [
        "ltxdh_chunk",
        0
      ],
      "blocks": 40,
      "video_scale": 1.0,
      "audio_scale": 1.0,
      "audio_to_video_scale": 1.0,
      "video_to_audio_scale": 1.0,
      "triton_kernels": true
    },
    "class_type": "LTX2AttentionTunerPatch"
  },
  "ltxdh_nag": {
    "inputs": {
      "model": [
        "ltxdh_attn_tune",
        0
      ],
      "nag_cond_video": [
        "ltxdh_cond",
        0
      ],
      "nag_cond_audio": [
        "ltxdh_cond",
        1
      ],
      "nag_scale": 11,
      "nag_alpha": 0.25,
      "nag_tau": 2.5,
      "inplace": true
    },
    "class_type": "LTX2_NAG"
  },
  "ltxdh_preview": {
    "inputs": {
      "model": [
        "ltxdh_nag",
        0
      ],
      "preview_rate": 8
    },
    "class_type": "LTX2SamplingPreviewOverride"
  },
  "ltxdh_guider": {
    "inputs": {
      "model": [
        "ltxdh_preview",
        0
      ],
      "positive": [
        "ltxdh_cond",
        0
      ],
      "negative": [
        "ltxdh_cond",
        1
      ],
      "cfg": 1.0
    },
    "class_type": "CFGGuider"
  },
  "ltxdh_sampler": {
    "inputs": {
      "sampler_name": "euler_cfg_pp"
    },
    "class_type": "KSamplerSelect"
  },
  "ltxdh_noise": {
    "inputs": {
      "noise_seed": 0
    },
    "class_type": "RandomNoise"
  },
  "ltxdh_scheduler": {
    "inputs": {
      "sigmas": "1.0, 0.99375, 0.9875, 0.98125, 0.975, 0.909375, 0.725, 0.421875, 0.0"
    },
    "class_type": "ManualSigmas"
  },
  "ltxdh_sample": {
    "inputs": {
      "noise": [
        "ltxdh_noise",
        0
      ],
      "guider": [
        "ltxdh_guider",
        0
      ],
      "sampler": [
        "ltxdh_sampler",
        0
      ],
      "sigmas": [
        "ltxdh_scheduler",
        0
      ],
      "latent_image": [
        "ltxdh_av_latent",
        0
      ]
    },
    "class_type": "SamplerCustomAdvanced"
  },
  "ltxdh_separate": {
    "inputs": {
      "av_latent": [
        "ltxdh_sample",
        0
      ]
    },
    "class_type": "LTXVSeparateAVLatent"
  },
  "ltxdh_decode_video": {
    "inputs": {
      "samples": [
        "ltxdh_separate",
        0
      ],
      "vae": [
        "ltxdh_vae",
        0
      ]
    },
    "class_type": "VAEDecode"
  },
  "ltxdh_decode_audio": {
    "inputs": {
      "samples": [
        "ltxdh_separate",
        1
      ],
      "vae": [
        "ltxdh_vae_audio",
        0
      ]
    },
    "class_type": "VAEDecode"
  },
  "ltxdh_out_video": {
    "inputs": {
      "images": [
        "ltxdh_decode_video",
        0
      ],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "ltx_dh/",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    },
    "class_type": "VHS_VideoCombine"
  },
  "ltxdh_out_audio": {
    "inputs": {
      "audio": [
        "ltxdh_decode_audio",
        0
      ],
      "filename_prefix": "ltx_dh/",
      "format": "wav"
    },
    "class_type": "SaveAudio"
  }
}